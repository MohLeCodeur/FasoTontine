@model FasoTontine.Models.Tontine
@{
    ViewData["Title"] = Model.Nom;
    Layout = "_Layout";
    bool isMember = ViewBag.IsMember;
    var currentMember = ViewBag.CurrentMember as FasoTontine.Models.MembreTontine;
    int currentUserId = ViewBag.CurrentUserId;
    bool isAdmin = ViewBag.IsAdmin;
    int totalRounds = ViewBag.TotalRounds;
}

<div class="container">
    <!-- Header Card -->
    <div class="card-premium p-4 p-md-5 mb-4 position-relative">
        <div class="row align-items-center">
            <div class="col-md-8">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span class="badge badge-premium @(Model.Statut == "Active" ? "badge-active" : Model.Statut == "EnAttente" ? "badge-pending" : "badge-terminated")">
                        @(Model.Statut == "Active" ? "Active" : Model.Statut == "EnAttente" ? "Recrutement" : "Terminée")
                    </span>
                    <span class="text-muted small"><i class="bi bi-calendar3 me-1"></i>Début : @Model.DateDebut.ToString("dd/MM/yyyy")</span>
                </div>
                <h1 class="fw-bold text-dark">@Model.Nom</h1>
                <p class="text-muted mb-0">@Model.Description</p>
                <div class="mt-3 small text-muted">
                    Créé par : <strong>@(Model.CreePar?.NomComplet ?? "Administrateur")</strong>
                </div>
            </div>
            
            <div class="col-md-4 text-md-end mt-4 mt-md-0">
                <div class="p-3 bg-light rounded-4 border d-inline-block text-center min-width-md" style="min-width: 200px;">
                    <span class="text-muted small d-block">Montant de la part</span>
                    <h2 class="fw-bold text-secondary mb-1">@Model.MontantPart.ToString("N0") <span class="fs-6">FCFA</span></h2>
                    <span class="text-muted small">Cagnotte finale : <strong>@((Model.MontantPart * Math.Max(1, Model.Membres.Count - 1)).ToString("N0")) FCFA</strong></span>
                </div>
            </div>
        </div>
        
        <!-- Administrative actions -->
        <div class="mt-4 pt-3 border-top d-flex flex-wrap gap-2">
            @if (Model.Statut == "EnAttente")
            {
                if (!isMember)
                {
                    <form asp-action="Join" asp-route-id="@Model.Id" method="post">
                        <button type="submit" class="btn btn-premium">
                            <i class="bi bi-person-plus-fill me-2"></i>Rejoindre la tontine
                        </button>
                    </form>
                }
                else
                {
                    <button class="btn btn-outline-success border-0 px-0" disabled>
                        <i class="bi bi-check-circle-fill me-2"></i>Vous êtes inscrit à cette tontine (Ordre temporaire : #@currentMember?.OrdreTirage)
                    </button>
                }

                @if (isAdmin)
                {
                    <div class="ms-md-auto d-flex align-items-center gap-2 border p-2.5 rounded-4 bg-light">
                        <form asp-action="GenerateDrawOrder" asp-route-id="@Model.Id" method="post" class="d-flex align-items-center gap-2">
                            <label class="form-label fw-bold small mb-0 me-1">Lancer les tirages :</label>
                            <select name="method" class="form-select form-select-sm border-0 bg-white" style="width: 130px; height: 35px; border-radius: 8px;">
                                <option value="aleatoire">Aléatoire</option>
                                <option value="sequentiel">Séquentiel</option>
                            </select>
                            <button type="submit" class="btn btn-premium btn-sm py-2 px-3">
                                Activer la Tontine
                            </button>
                        </form>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Details Columns -->
    <div class="row g-4">
        <!-- MEMBERS & DRAW SCHEDULE -->
        <div class="col-lg-5">
            <div class="card-premium p-4">
                <h4 class="fw-bold text-dark mb-4 d-flex align-items-center gap-2">
                    <i class="bi bi-people-fill text-primary"></i> Membres & Calendrier
                </h4>

                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Position</th>
                                <th>Participant</th>
                                <th>Téléphone</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var member in Model.Membres.OrderBy(m => m.OrdreTirage))
                            {
                                var isCurrentUser = member.UtilisateurId == currentUserId;
                                <tr class="@(isCurrentUser ? "table-primary" : "")">
                                    <td>
                                        <span class="badge bg-secondary text-white font-monospace">
                                            Tour @member.OrdreTirage
                                        </span>
                                    </td>
                                    <td>
                                        <div class="fw-semibold text-dark">
                                            @member.Utilisateur?.NomComplet
                                            @if (isCurrentUser)
                                            {
                                                <span class="badge bg-primary text-white ms-1" style="font-size: 0.65rem;">Moi</span>
                                            }
                                        </div>
                                    </td>
                                    <td class="font-monospace text-muted small">
                                        @member.Utilisateur?.Telephone
                                    </td>
                                    @if (isAdmin && member.Statut == "EnAttente")
                                    {
                                        <td>
                                            <div class="d-flex gap-1">
                                                <form asp-action="ApproveMember" asp-route-id="@Model.Id" method="post">
                                                    <input type="hidden" name="utilisateurId" value="@member.UtilisateurId" />
                                                    <input type="hidden" name="decision" value="accepter" />
                                                    <button type="submit" class="btn btn-sm btn-success">Accepter</button>
                                                </form>
                                                <form asp-action="ApproveMember" asp-route-id="@Model.Id" method="post">
                                                    <input type="hidden" name="utilisateurId" value="@member.UtilisateurId" />
                                                    <input type="hidden" name="decision" value="rejeter" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">Rejeter</button>
                                                </form>
                                            </div>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- TRACK CONTRIBUTIONS / PAYOUTS -->
        <div class="col-lg-7">
            <!-- COTISATIONS PAR TOUR -->
            <div class="card-premium p-4 mb-4">
                <h4 class="fw-bold text-dark mb-3 d-flex align-items-center gap-2">
                    <i class="bi bi-cash-coin text-primary"></i> Suivi des Tours & Cotisations
                </h4>

                @if (Model.Statut == "EnAttente")
                {
                    <div class="alert alert-info border-0 rounded-4">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        Les paiements et le calendrier de versement seront ouverts dès que l'administrateur aura activé la tontine.
                    </div>
                }
                else
                {
                    <!-- Current User action block -->
                    if (isMember)
                    {
                        <div class="bg-primary bg-opacity-10 border border-primary border-opacity-25 rounded-4 p-4 mb-4">
                            <h5 class="fw-bold text-primary mb-2">Actions Rapides (Mes Cotisations)</h5>
                            <div class="d-flex flex-wrap gap-2 mt-2">
                                @for (int tour = 1; tour <= Model.Membres.Count; tour++)
                                {
                                    var payment = Model.Cotisations.FirstOrDefault(c => c.CotiseurId == currentUserId && c.NumeroTour == tour);
                                    if (payment == null || payment.Statut == "Rejete")
                                    {
                                        <a asp-controller="Cotisation" asp-action="Declarer" asp-route-tontineId="@Model.Id" asp-route-tour="@tour" class="btn btn-premium btn-sm py-2">
                                            <i class="bi bi-wallet2 me-1"></i>Payer Tour #@tour (@Model.MontantPart.ToString("N0") FCFA)
                                        </a>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-secondary py-2 border-0" disabled>
                                            <i class="bi bi-check-circle-fill text-success me-1"></i>Tour #@tour (@payment.Statut)
                                        </button>
                                    }
                                }
                            </div>
                        </div>
                    }

                    <!-- Payouts -->
                    <h5 class="fw-bold text-dark mb-3 mt-4">Calendrier des Bénéficiaires</h5>
                    <div class="row g-3 mb-4">
                        @foreach (var payout in Model.Versements.OrderBy(v => v.NumeroTour))
                        {
                            <div class="col-md-6">
                                <div class="p-3 rounded-4 border bg-light d-flex align-items-center justify-content-between">
                                    <div>
                                        <span class="text-muted small font-monospace">Tour #@payout.NumeroTour</span>
                                        <div class="fw-bold text-dark">@payout.Beneficiaire?.NomComplet</div>
                                        <small class="text-secondary fw-semibold">Cagnotte : @payout.MontantVerse.ToString("N0") FCFA</small>
                                    </div>
                                    <div>
                                        @if (payout.Statut == "Effectue")
                                        {
                                            <span class="badge bg-success-subtle text-success py-1.5 px-2 rounded-3"><i class="bi bi-check-lg me-1"></i>Versé</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning-subtle text-warning py-1.5 px-2 rounded-3"><i class="bi bi-hourglass me-1"></i>En attente</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- All Declared Cotisations -->
                    <h5 class="fw-bold text-dark mb-3">Paiements déclarés (Orange/Moov Money)</h5>
                    @if (!Model.Cotisations.Any())
                    {
                        <div class="text-center py-4 border rounded-4 bg-light">
                            <p class="text-muted mb-0 small">Aucune cotisation déclarée pour le moment.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle small">
                                <thead>
                                    <tr>
                                        <th>Tour</th>
                                        <th>Cotiseur</th>
                                        <th>Mode</th>
                                        <th>Réf. Transaction</th>
                                        <th>Date</th>
                                        <th>Statut</th>
                                        @if (isAdmin)
                                        {
                                            <th>Validation</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var cot in Model.Cotisations.OrderByDescending(c => c.DatePaiement))
                                    {
                                        <tr>
                                            <td><span class="badge bg-light text-dark font-monospace border">#@cot.NumeroTour</span></td>
                                            <td class="fw-semibold">@cot.Cotiseur?.NomComplet</td>
                                            <td>@cot.MethodePaiement</td>
                                            <td class="font-monospace text-primary">@cot.TransactionReference</td>
                                            <td class="text-muted">@cot.DatePaiement.ToString("dd/MM/yy")</td>
                                            <td>
                                                @if (cot.Statut == "Valide")
                                                {
                                                    <span class="badge bg-success-subtle text-success">Validé</span>
                                                }
                                                else if (cot.Statut == "EnAttente")
                                                {
                                                    <span class="badge bg-warning-subtle text-warning">En attente</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger-subtle text-danger">Rejeté</span>
                                                }
                                            </td>
                                            @if (isAdmin)
                                            {
                                                <td>
                                                    @if (cot.Statut == "EnAttente")
                                                    {
                                                        <div class="d-flex gap-1">
                                                            <form asp-controller="Cotisation" asp-action="Valider" method="post">
                                                                <input type="hidden" name="id" value="@cot.Id" />
                                                                <input type="hidden" name="decision" value="valider" />
                                                                <button type="submit" class="btn btn-xs btn-success py-1 px-2 rounded-2" style="font-size: 0.75rem;">
                                                                    Valider
                                                                </button>
                                                            </form>
                                                            <form asp-controller="Cotisation" asp-action="Valider" method="post">
                                                                <input type="hidden" name="id" value="@cot.Id" />
                                                                <input type="hidden" name="decision" value="rejeter" />
                                                                <button type="submit" class="btn btn-xs btn-danger py-1 px-2 rounded-2" style="font-size: 0.75rem;">
                                                                    Rejeter
                                                                </button>
                                                            </form>
                                                        </div>
                                                    }
                                                </td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>
